{
  "name": "push-to-registry",
  "version": "3.0.1",
  "description": "Action to push images to registry",
  "repository": {
    "type": "git",
    "url": "https://github.com/aardbol-actions/push-to-registry"
  },
  "main": "dist/index.js",
  "scripts": {
    "compile": "tsc -p .",
    "bundle": "ncc build src/index.ts --source-map --minify",
    "clean": "rm -rf out/ dist/",
    "lint": "eslint . --max-warnings=0",
    "generate-ios": "npx @aardbol-actions/action-io-generator -w -o ./src/generated/inputs-outputs.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Red Hat",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/io": "3.0.2",
    "ini": "7.0.0"
  },
  "devDependencies": {
    "@aardbol-actions/action-io-generator": "2.0.0",
    "@aardbol-actions/tsconfig": "2.0.0",
    "@eslint/js": "^10.0.1",
    "@types/ini": "4.1.1",
    "@types/node": "^26.0",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vercel/ncc": "0.44.1",
    "eslint": "10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": "24"
  }
}
